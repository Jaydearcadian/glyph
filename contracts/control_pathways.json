{
  "control_framework": "GlyphFaultMitigation",
  "version": "1.0.0",
  "corrections_applied": {
    "ten_mon_floor": "REMOVED. Manifest claimed a Monad consensus 10-MON revert; VERIFIED FALSE on live testnet. Replaced with advisory solvency preflight (gas-headroom only, no fake fixed number).",
    "undelegation_type": "Type-4 (0x04) tx, contractAddress=0x00... — CORRECT, kept.",
    "create_opcodes": "Best-practice guard (call-only proxy), not a hard Monad ban."
  },
  "execution_guards": {
    "solvency_preflight": {
      "enforce": "ADVISORY_CLIENT_SIDE",
      "rule": "balance >= outflow AND balance - outflow >= 0.1 MON gas headroom",
      "revert_action": "LOCAL_SIMULATION_ABORT"
    },
    "privilege_de_escalation": {
      "enforce_strict_target_allowlist": true,
      "enforce_drawdown_limits_per_epoch": true
    }
  },
  "panic_recovery_circuits": {
    "trigger_undelegation_path": {
      "target_allocation_address": "0x0000000000000000000000000000000000000000",
      "transaction_type": "0x04",
      "required_gas_payer": "SPONSOR_PAYMASTER_POOL"
    }
  },
  "exception_bubbling_policy": {
    "sub_call_failures": {
      "strategy": "TRY_CATCH_WRAPPER",
      "allowed_modes": ["SINGLE_REVERT_ROLLBACK", "BATCH_TRY_CONTINUE"],
      "fallback_event_signature": "LogVesselExecutionFailure(bytes32 indexed vesselId, bytes reason)"
    }
  }
}
