    }
  },
  "exception_bubbling_policy": {
    "sub_call_failures": {
      "strategy": "TRY_CATCH_WRAPPER",
      "allowed_modes": ["SINGLE_REVERT_ROLLBACK", "BATCH_TRY_CONTINUE"],
      "fallback_event_signature": "LogVesselExecutionFailure(bytes32 indexed vesselId, bytes reason)"
    }
  }
}
