{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glyph.local/schemas/deployment.schema.json",
  "title": "Glyph Verified Deployment Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "environment",
    "chainId",
    "contractName",
    "address",
    "deploymentTransaction",
    "deploymentBlock",
    "runtimeCodeHash",
    "gitHead",
    "configuration",
    "verification",
    "status"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "environment": { "enum": ["local", "anvil", "testnet", "mainnet"] },
    "networkName": { "type": "string" },
    "chainId": { "type": "integer", "minimum": 1 },
    "contractName": { "type": "string", "minLength": 1 },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "deploymentTransaction": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "deploymentBlock": { "type": "integer", "minimum": 0 },
    "runtimeCodeHash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "constructorArgsHash": { "type": ["string", "null"], "pattern": "^0x[0-9a-fA-F]{64}$" },
    "gitHead": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readBack", "values"],
      "properties": {
        "readBack": { "const": true },
        "values": { "type": "object" },
        "remotePeers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["chainId", "adapter", "application", "proofKind"],
            "properties": {
              "chainId": { "type": "integer", "minimum": 1 },
              "adapter": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
              "application": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
              "proofKind": { "enum": ["LOCAL_VERIFIED", "AUTHENTICATED_ADAPTER", "LIGHT_CLIENT_VERIFIED", "ISSUER_ATTESTED"] }
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receiptStatus", "runtimeCodeReadBack", "configurationReadBack", "verifiedAt"],
      "properties": {
        "receiptStatus": { "const": 1 },
        "runtimeCodeReadBack": { "const": true },
        "configurationReadBack": { "const": true },
        "sourceVerified": { "type": "boolean" },
        "explorerUrl": { "type": "string", "format": "uri" },
        "verifiedAt": { "type": "string", "format": "date-time" }
      }
    },
    "status": { "enum": ["active", "deprecated", "experimental"] },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
